# Node modules (root + all sub-packages)
node_modules/
server/node_modules/
client/node_modules/

# Build artifacts
/dist/
/build/
server/dist/
client/dist/

# Environment files (never commit secrets)
.env
server/.env
client/.env
*.env.local
*.env.*.local

# Prisma generated client
server/node_modules/.prisma/

# TypeScript build info
*.tsbuildinfo

# Angular cache
client/.angular/

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo

# Test coverage output
coverage/
server/coverage/
client/coverage/

# npm lock files (keep package-lock.json but ignore yarn.lock / pnpm-lock if not used)
yarn.lock
pnpm-lock.yaml

# Logs (keep the logs/ folder but ignore runtime log files)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
client/dist/
