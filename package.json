{
  "name": "sixert-bank",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "yarn workspace server build && yarn workspace client build",
    "build:server": "yarn workspace server build",
    "build:client": "yarn workspace client build",
    "dev": "concurrently \"yarn workspace server dev\" \"yarn workspace client dev\"",
    "start": "yarn workspace server start",
    "db:migrate": "yarn workspace server db:migrate",
    "db:seed": "yarn workspace server db:seed",
    "db:studio": "yarn workspace server db:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
